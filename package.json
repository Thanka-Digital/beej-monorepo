{
  "name": "beej",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "prettier": "^3.5.0",
    "turbo": "latest",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18"
  }
}
