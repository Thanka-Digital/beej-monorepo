{
  "name": "@thanka-digital/beej-component",
  "version": "0.0.5",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "import": "./dist/*js",
      "require": "./dist/*.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.mjs",
      "require": "./dist/plugin.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit",
    "dev": "concurrently \"pnpm build --watch\"",
    "build:code": "tsup",
    "build:css": "tailwindcss -i ./src/css/global.css -o ./dist/style.css --minify",
    "build": "pnpm build:code && pnpm build:css"
  },
  "devDependencies": {
    "@beej/eslint-config": "workspace:*",
    "@beej/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.3.1",
    "@turbo/gen": "^2.9.18",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@floating-ui/react": "^0.27.19",
    "@tailwindcss/postcss": "^4.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "postcss": "^8.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.0.9"
  }
}
