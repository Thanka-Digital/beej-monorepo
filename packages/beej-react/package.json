{
  "name": "@thanka-digital/beej-react",
  "version": "0.2.2",
  "private": true,
  "description": "React template presets for the beej-cli engine",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "peerDependencies": {
    "@chakra-ui/react": "^3.0.0",
    "@mantine/core": "^9.3.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@types/react": "^19.0.0",
    "clsx": "^2.1.1",
    "jotai": "^2.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.3.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}
