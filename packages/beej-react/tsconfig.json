{
  "compilerOptions": {
    "jsx": "react",
    "target": "ES2022",
    "module": "ES2020",
    "lib": ["es6", "DOM"],
    "moduleResolution": "Bundler",
    "allowJs": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": [
    "cli",
    "main",
    "templates/extensions/mantine/postcss.config.mjs",
    "templates/base/tsconfig.app.json",
    "templates/base/tsconfig.json",
    "templates/base/tsconfig.node.json",
    "templates/base/eslint.config.js"
  ],
  "exclude": ["node_modules", "dist", ".github", "__test__"]
}
